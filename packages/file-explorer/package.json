{
  "name": "@nextdj/file-explorer",
  "version": "1.0.4",
  "description": "A React file explorer component with uploads, context menus, detail panels, and app-side extensibility.",
  "homepage": "https://github.com/nextdj/file-explorer#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nextdj/file-explorer.git"
  },
  "bugs": {
    "url": "https://github.com/nextdj/file-explorer/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./theme.css": "./dist/styles/theme.css"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "react",
    "file-explorer",
    "file-browser",
    "uploader",
    "component-library"
  ],
  "sideEffects": [
    "./dist/styles/theme.css"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "node ./scripts/clean-dist.mjs",
    "build": "pnpm run clean && tsc -p tsconfig.build.json && node ./scripts/fix-esm-imports.mjs && node ./scripts/copy-theme.mjs",
    "dev": "tsc -p tsconfig.build.json --watch --preserveWatchOutput & node ./scripts/watch-theme.mjs",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.4.0",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@air/react-drag-to-select": "^5.0.11",
    "ahooks": "^3.9.6",
    "@uppy/core": "^5.2.0",
    "@uppy/tus": "^5.1.0",
    "lucide-react": "^0.559.0",
    "zustand": "^5.0.10",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-tooltip": "^1.2.8"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  }
}
